<Window x:Class="Kursovaya_TechProg.Views.Window1"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Kursovaya_TechProg.Views"
        mc:Ignorable="d"
        Title="Авторизация" Height="250" Width="350"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <StackPanel Margin="20">
        <TextBlock Text="Логин" Margin="0,0,0,5"/>
        <TextBox x:Name="LoginBox" Margin="0,0,0,15"/>

        <TextBlock Text="Пароль" Margin="0,0,0,5"/>
        <PasswordBox x:Name="PasswordBox" Margin="0,0,0,20"/>

        <Button x:Name="LoginButton" Content="Войти" 
                Click="LoginButton_Click" Height="30" Margin="0,0,0,10"/>

        <TextBlock Text="Нет аккаунта?" HorizontalAlignment="Center"/>
        <Button x:Name="RegisterButton" Content="Зарегистрироваться" 
                Click="RegisterButton_Click" 
                Background="Transparent" BorderThickness="0"
                Foreground="Blue" Cursor="Hand"/>
    </StackPanel>
</Window>
