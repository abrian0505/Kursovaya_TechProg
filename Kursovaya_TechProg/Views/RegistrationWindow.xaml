<Window x:Class="Kursovaya_TechProg.Views.RegistrationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Kursovaya_TechProg.Views"
        mc:Ignorable="d"
       Title="Регистрация" Height="500" Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">

            <TextBlock Text="Email" Margin="0,0,0,5"/>
            <TextBox x:Name="EmailBox" Margin="0,0,0,15"/>

            <TextBlock Text="Пароль" Margin="0,0,0,5"/>
            <PasswordBox x:Name="PasswordBox" Margin="0,0,0,15"/>

            <TextBlock Text="Подтверждение пароля" Margin="0,0,0,5"/>
            <PasswordBox x:Name="ConfirmPasswordBox" Margin="0,0,0,15"/>

            <TextBlock Text="Имя" Margin="0,0,0,5"/>
            <TextBox x:Name="FirstNameBox" Margin="0,0,0,15"/>

            <TextBlock Text="Фамилия" Margin="0,0,0,5"/>
            <TextBox x:Name="LastNameBox" Margin="0,0,0,15"/>

            <TextBlock Text="Номер телефона" Margin="0,0,0,5"/>
            <TextBox x:Name="PhoneBox" Margin="0,0,0,20"/>

            <Button x:Name="RegisterButton" Content="Зарегистрироваться" 
                    Click="RegisterButton_Click" Height="35" Margin="0,0,0,10"
                    Background="#4CAF50" Foreground="White"/>

            <Button Content="Отмена" Click="CancelButton_Click" 
                    Height="30" Background="#F44336" Foreground="White"/>
        </StackPanel>
    </ScrollViewer>
</Window>
